<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.audit.rectification.mapper.RectProgressMapper">

    <resultMap type="com.audit.rectification.domain.RectProgress" id="RectProgressResult">
        <id     property="progressId"      column="progress_id"       />
        <result property="taskId"          column="task_id"           />
        <result property="issueId"         column="issue_id"          />
        <result property="progressType"    column="progress_type"     />
        <result property="content"         column="content"           />
        <result property="operatorId"      column="operator_id"       />
        <result property="operatorName"    column="operator_name"     />
        <result property="operateTime"     column="operate_time"      />
        <result property="createTime"      column="create_time"       />
    </resultMap>

    <sql id="selectRectProgressVo">
        select p.progress_id, p.task_id, p.issue_id, p.progress_type, p.content,
        p.operator_id,
        coalesce(nullif(u.nick_name, ''), p.operator_name) as operator_name,
        p.operate_time, p.create_time
        from rect_progress p
        left join sys_user u on u.user_id = p.operator_id
    </sql>

    <select id="selectRectProgressList" parameterType="com.audit.rectification.domain.RectProgress" resultMap="RectProgressResult">
        <include refid="selectRectProgressVo"/>
        <where>
            <if test="taskId != null">and p.task_id = #{taskId}</if>
            <if test="issueId != null">and p.issue_id = #{issueId}</if>
            <if test="progressType != null and progressType != ''">and p.progress_type = #{progressType}</if>
        </where>
        order by p.operate_time desc
    </select>

    <select id="selectRectProgressByTaskId" parameterType="Long" resultMap="RectProgressResult">
        <include refid="selectRectProgressVo"/>
        where p.task_id = #{taskId}
        order by p.operate_time desc
    </select>

    <insert id="insertRectProgress" parameterType="com.audit.rectification.domain.RectProgress" useGeneratedKeys="true" keyProperty="progressId">
        insert into rect_progress (
            <if test="taskId != null">task_id,</if>
            <if test="issueId != null">issue_id,</if>
            <if test="progressType != null and progressType != ''">progress_type,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="operatorId != null">operator_id,</if>
            <if test="operatorId != null or (operatorName != null and operatorName != '')">operator_name,</if>
            operate_time,
            create_time
        )values(
            <if test="taskId != null">#{taskId},</if>
            <if test="issueId != null">#{issueId},</if>
            <if test="progressType != null and progressType != ''">#{progressType},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="operatorId != null">#{operatorId},</if>
            <if test="operatorId != null or (operatorName != null and operatorName != '')">
                <choose>
                    <when test="operatorId != null">
                        coalesce((select nullif(nick_name, '') from sys_user where user_id = #{operatorId}), #{operatorName}),
                    </when>
                    <otherwise>#{operatorName},</otherwise>
                </choose>
            </if>
            sysdate(),
            sysdate()
        )
    </insert>

</mapper>
