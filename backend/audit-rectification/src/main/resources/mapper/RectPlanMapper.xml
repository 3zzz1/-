<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.audit.rectification.mapper.RectPlanMapper">

    <resultMap type="com.audit.rectification.domain.RectPlan" id="RectPlanResult">
        <id     property="planId"             column="plan_id"              />
        <result property="taskId"             column="task_id"              />
        <result property="issueId"            column="issue_id"             />
        <result property="planContent"        column="plan_content"         />
        <result property="responsibleUserId"  column="responsible_user_id"  />
        <result property="planDeadline"       column="plan_deadline"        />
        <result property="planType"           column="plan_type"            />
        <result property="longTermReason"     column="long_term_reason"     />
        <result property="status"             column="status"               />
        <result property="delFlag"            column="del_flag"             />
        <result property="createBy"           column="create_by"            />
        <result property="createTime"         column="create_time"          />
        <result property="updateBy"           column="update_by"            />
        <result property="updateTime"         column="update_time"          />
        <result property="remark"             column="remark"               />
    </resultMap>

    <sql id="selectRectPlanVo">
        select plan_id, task_id, issue_id, plan_content, responsible_user_id,
        plan_deadline, plan_type, long_term_reason, status, del_flag,
        create_by, create_time, update_by, update_time, remark
        from rect_plan
    </sql>

    <select id="selectRectPlanList" parameterType="com.audit.rectification.domain.RectPlan" resultMap="RectPlanResult">
        <include refid="selectRectPlanVo"/>
        <where>
            <if test="taskId != null">and task_id = #{taskId}</if>
            <if test="issueId != null">and issue_id = #{issueId}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="planType != null and planType != ''">and plan_type = #{planType}</if>
            and del_flag = '0'
        </where>
        order by create_time desc
    </select>

    <select id="selectRectPlanById" parameterType="Long" resultMap="RectPlanResult">
        <include refid="selectRectPlanVo"/> where plan_id = #{planId}
    </select>

    <select id="selectRectPlanByTaskId" parameterType="Long" resultMap="RectPlanResult">
        <include refid="selectRectPlanVo"/>
        where task_id = #{taskId} and del_flag = '0'
    </select>

    <insert id="insertRectPlan" parameterType="com.audit.rectification.domain.RectPlan" useGeneratedKeys="true" keyProperty="planId">
        insert into rect_plan (
            <if test="taskId != null">task_id,</if>
            <if test="issueId != null">issue_id,</if>
            <if test="planContent != null and planContent != ''">plan_content,</if>
            <if test="responsibleUserId != null">responsible_user_id,</if>
            <if test="planDeadline != null">plan_deadline,</if>
            <if test="planType != null and planType != ''">plan_type,</if>
            <if test="longTermReason != null and longTermReason != ''">long_term_reason,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="taskId != null">#{taskId},</if>
            <if test="issueId != null">#{issueId},</if>
            <if test="planContent != null and planContent != ''">#{planContent},</if>
            <if test="responsibleUserId != null">#{responsibleUserId},</if>
            <if test="planDeadline != null">#{planDeadline},</if>
            <if test="planType != null and planType != ''">#{planType},</if>
            <if test="longTermReason != null and longTermReason != ''">#{longTermReason},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateRectPlan" parameterType="com.audit.rectification.domain.RectPlan">
        update rect_plan
        <set>
            <if test="planContent != null">plan_content = #{planContent},</if>
            <if test="responsibleUserId != null">responsible_user_id = #{responsibleUserId},</if>
            <if test="planDeadline != null">plan_deadline = #{planDeadline},</if>
            <if test="planType != null and planType != ''">plan_type = #{planType},</if>
            <if test="longTermReason != null">long_term_reason = #{longTermReason},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where plan_id = #{planId}
    </update>

    <delete id="deleteRectPlanByIds" parameterType="Long">
        update rect_plan set del_flag = '2' where plan_id in
        <foreach item="planId" collection="array" open="(" separator="," close=")">#{planId}</foreach>
    </delete>

</mapper>
