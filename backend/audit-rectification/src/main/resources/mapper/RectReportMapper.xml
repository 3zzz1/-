<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.audit.rectification.mapper.RectReportMapper">

    <resultMap type="com.audit.rectification.domain.RectReport" id="RectReportResult">
        <id     property="reportId"             column="report_id"               />
        <result property="taskId"               column="task_id"                 />
        <result property="reportContent"        column="report_content"          />
        <result property="generatedPath"        column="generated_path"          />
        <result property="status"               column="status"                  />
        <result property="submitUserId"         column="submit_user_id"          />
        <result property="submitTime"           column="submit_time"             />
        <result property="unitApproveStatus"    column="unit_approve_status"     />
        <result property="unitApproveUserId"    column="unit_approve_user_id"    />
        <result property="unitApproveTime"      column="unit_approve_time"       />
        <result property="unitApproveOpinion"   column="unit_approve_opinion"    />
        <result property="delFlag"              column="del_flag"                />
        <result property="createBy"             column="create_by"               />
        <result property="createTime"           column="create_time"             />
        <result property="updateBy"             column="update_by"               />
        <result property="updateTime"           column="update_time"             />
        <result property="remark"               column="remark"                  />
    </resultMap>

    <sql id="selectRectReportVo">
        select report_id, task_id, report_content, generated_path, status,
        submit_user_id, submit_time,
        unit_approve_status, unit_approve_user_id, unit_approve_time, unit_approve_opinion,
        del_flag, create_by, create_time, update_by, update_time, remark
        from rect_report
    </sql>

    <select id="selectRectReportList" parameterType="com.audit.rectification.domain.RectReport" resultMap="RectReportResult">
        <include refid="selectRectReportVo"/>
        <where>
            <if test="taskId != null">and task_id = #{taskId}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="unitApproveStatus != null and unitApproveStatus != ''">and unit_approve_status = #{unitApproveStatus}</if>
            and del_flag = '0'
        </where>
        order by create_time desc
    </select>

    <select id="selectRectReportById" parameterType="Long" resultMap="RectReportResult">
        <include refid="selectRectReportVo"/>
        where report_id = #{reportId}
    </select>

    <select id="selectRectReportByTaskId" parameterType="Long" resultMap="RectReportResult">
        <include refid="selectRectReportVo"/>
        where task_id = #{taskId} and del_flag = '0'
    </select>

    <insert id="insertRectReport" parameterType="com.audit.rectification.domain.RectReport" useGeneratedKeys="true" keyProperty="reportId">
        insert into rect_report (
            <if test="taskId != null">task_id,</if>
            <if test="reportContent != null and reportContent != ''">report_content,</if>
            <if test="generatedPath != null and generatedPath != ''">generated_path,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="submitUserId != null">submit_user_id,</if>
            <if test="submitTime != null">submit_time,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="taskId != null">#{taskId},</if>
            <if test="reportContent != null and reportContent != ''">#{reportContent},</if>
            <if test="generatedPath != null and generatedPath != ''">#{generatedPath},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="submitUserId != null">#{submitUserId},</if>
            <if test="submitTime != null">#{submitTime},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateRectReport" parameterType="com.audit.rectification.domain.RectReport">
        update rect_report
        <set>
            <if test="reportContent != null">report_content = #{reportContent},</if>
            <if test="generatedPath != null">generated_path = #{generatedPath},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="submitUserId != null">submit_user_id = #{submitUserId},</if>
            <if test="submitTime != null">submit_time = #{submitTime},</if>
            <if test="unitApproveStatus != null and unitApproveStatus != ''">unit_approve_status = #{unitApproveStatus},</if>
            <if test="unitApproveUserId != null">unit_approve_user_id = #{unitApproveUserId},</if>
            <if test="unitApproveTime != null">unit_approve_time = #{unitApproveTime},</if>
            <if test="unitApproveOpinion != null">unit_approve_opinion = #{unitApproveOpinion},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where report_id = #{reportId}
    </update>

    <delete id="deleteRectReportByIds" parameterType="Long">
        update rect_report set del_flag = '2' where report_id in
        <foreach item="reportId" collection="array" open="(" separator="," close=")">
            #{reportId}
        </foreach>
    </delete>

</mapper>
