<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.audit.rectification.mapper.RectExtensionMapper">

    <resultMap type="com.audit.rectification.domain.RectExtension" id="RectExtensionResult">
        <id     property="extensionId"       column="extension_id"        />
        <result property="issueId"           column="issue_id"            />
        <result property="taskId"            column="task_id"             />
        <result property="originalDeadline"  column="original_deadline"   />
        <result property="extensionDays"     column="extension_days"      />
        <result property="newDeadline"       column="new_deadline"        />
        <result property="reason"            column="reason"              />
        <result property="status"            column="status"              />
        <result property="applyUserId"       column="apply_user_id"       />
        <result property="applyTime"         column="apply_time"          />
        <result property="approveUserId"     column="approve_user_id"     />
        <result property="approveTime"       column="approve_time"        />
        <result property="approveOpinion"    column="approve_opinion"     />
        <result property="delFlag"           column="del_flag"            />
        <result property="createBy"          column="create_by"           />
        <result property="createTime"        column="create_time"         />
        <result property="updateBy"          column="update_by"           />
        <result property="updateTime"        column="update_time"         />
        <result property="remark"            column="remark"              />
    </resultMap>

    <sql id="selectRectExtensionVo">
        select extension_id, issue_id, task_id, original_deadline, extension_days, new_deadline,
        reason, status, apply_user_id, apply_time,
        approve_user_id, approve_time, approve_opinion,
        del_flag, create_by, create_time, update_by, update_time, remark
        from rect_extension
    </sql>

    <select id="selectRectExtensionList" parameterType="com.audit.rectification.domain.RectExtension" resultMap="RectExtensionResult">
        <include refid="selectRectExtensionVo"/>
        <where>
            <if test="taskId != null">and task_id = #{taskId}</if>
            <if test="issueId != null">and issue_id = #{issueId}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            and del_flag = '0'
        </where>
        order by create_time desc
    </select>

    <select id="selectRectExtensionById" parameterType="Long" resultMap="RectExtensionResult">
        <include refid="selectRectExtensionVo"/> where extension_id = #{extensionId}
    </select>

    <insert id="insertRectExtension" parameterType="com.audit.rectification.domain.RectExtension" useGeneratedKeys="true" keyProperty="extensionId">
        insert into rect_extension (
            <if test="issueId != null">issue_id,</if>
            <if test="taskId != null">task_id,</if>
            <if test="originalDeadline != null">original_deadline,</if>
            <if test="extensionDays != null">extension_days,</if>
            <if test="newDeadline != null">new_deadline,</if>
            <if test="reason != null and reason != ''">reason,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="applyUserId != null">apply_user_id,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            apply_time,
            create_time
        )values(
            <if test="issueId != null">#{issueId},</if>
            <if test="taskId != null">#{taskId},</if>
            <if test="originalDeadline != null">#{originalDeadline},</if>
            <if test="extensionDays != null">#{extensionDays},</if>
            <if test="newDeadline != null">#{newDeadline},</if>
            <if test="reason != null and reason != ''">#{reason},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="applyUserId != null">#{applyUserId},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate(),
            sysdate()
        )
    </insert>

    <update id="updateRectExtension" parameterType="com.audit.rectification.domain.RectExtension">
        update rect_extension
        <set>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="approveUserId != null">approve_user_id = #{approveUserId},</if>
            <if test="approveTime != null">approve_time = #{approveTime},</if>
            <if test="approveOpinion != null">approve_opinion = #{approveOpinion},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where extension_id = #{extensionId}
    </update>

    <delete id="deleteRectExtensionByIds" parameterType="Long">
        update rect_extension set del_flag = '2' where extension_id in
        <foreach item="extensionId" collection="array" open="(" separator="," close=")">#{extensionId}</foreach>
    </delete>

</mapper>
