<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysUserRoleTimedMapper">

    <resultMap type="com.ruoyi.system.domain.SysUserRoleTimed" id="SysUserRoleTimedResult">
        <id     property="id"             column="id"              />
        <result property="userId"         column="user_id"         />
        <result property="roleId"         column="role_id"         />
        <result property="projectId"      column="project_id"      />
        <result property="effectiveTime"  column="effective_time"  />
        <result property="expireTime"     column="expire_time"     />
        <result property="grantReason"    column="grant_reason"    />
        <result property="grantUserId"    column="grant_user_id"   />
        <result property="status"         column="status"          />
        <result property="revokeTime"     column="revoke_time"     />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
    </resultMap>

    <sql id="selectSysUserRoleTimedVo">
        select id, user_id, role_id, project_id, effective_time, expire_time,
        grant_reason, grant_user_id, status, revoke_time,
        create_by, create_time, update_by, update_time, remark
        from sys_user_role_timed
    </sql>

    <select id="selectSysUserRoleTimedList" parameterType="com.ruoyi.system.domain.SysUserRoleTimed" resultMap="SysUserRoleTimedResult">
        <include refid="selectSysUserRoleTimedVo"/>
        <where>
            <if test="userId != null">and user_id = #{userId}</if>
            <if test="roleId != null">and role_id = #{roleId}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
    </select>

    <select id="selectActiveByUserId" parameterType="Long" resultMap="SysUserRoleTimedResult">
        <include refid="selectSysUserRoleTimedVo"/>
        where user_id = #{userId}
        and status = '0'
        and effective_time &lt;= sysdate()
        and expire_time &gt;= sysdate()
    </select>

    <select id="selectExpiredActiveRecords" resultMap="SysUserRoleTimedResult">
        <include refid="selectSysUserRoleTimedVo"/>
        where status = '0'
        and expire_time &lt; sysdate()
    </select>

    <insert id="insertSysUserRoleTimed" parameterType="com.ruoyi.system.domain.SysUserRoleTimed" useGeneratedKeys="true" keyProperty="id">
        insert into sys_user_role_timed (
            <if test="userId != null">user_id,</if>
            <if test="roleId != null">role_id,</if>
            <if test="projectId != null">project_id,</if>
            <if test="effectiveTime != null">effective_time,</if>
            <if test="expireTime != null">expire_time,</if>
            <if test="grantReason != null and grantReason != ''">grant_reason,</if>
            <if test="grantUserId != null">grant_user_id,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="userId != null">#{userId},</if>
            <if test="roleId != null">#{roleId},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="effectiveTime != null">#{effectiveTime},</if>
            <if test="expireTime != null">#{expireTime},</if>
            <if test="grantReason != null and grantReason != ''">#{grantReason},</if>
            <if test="grantUserId != null">#{grantUserId},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateSysUserRoleTimed" parameterType="com.ruoyi.system.domain.SysUserRoleTimed">
        update sys_user_role_timed
        <set>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="revokeTime != null">revoke_time = #{revokeTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteSysUserRoleTimedByUserId" parameterType="Long">
        delete from sys_user_role_timed where user_id = #{userId}
    </delete>

</mapper>
