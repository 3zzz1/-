<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysPermissionAuditLogMapper">

    <resultMap type="com.ruoyi.system.domain.SysPermissionAuditLog" id="SysPermissionAuditLogResult">
        <id     property="logId"            column="log_id"             />
        <result property="userId"           column="user_id"            />
        <result property="userName"         column="user_name"          />
        <result property="operationType"    column="operation_type"     />
        <result property="targetType"       column="target_type"        />
        <result property="targetId"         column="target_id"          />
        <result property="operationDetail"  column="operation_detail"   />
        <result property="ipAddress"        column="ip_address"         />
        <result property="operationTime"    column="operation_time"     />
        <result property="createTime"       column="create_time"        />
    </resultMap>

    <sql id="selectSysPermissionAuditLogVo">
        select log_id, user_id, user_name, operation_type, target_type, target_id,
        operation_detail, ip_address, operation_time, create_time
        from sys_permission_audit_log
    </sql>

    <select id="selectSysPermissionAuditLogList" parameterType="com.ruoyi.system.domain.SysPermissionAuditLog" resultMap="SysPermissionAuditLogResult">
        <include refid="selectSysPermissionAuditLogVo"/>
        <where>
            <if test="userId != null">and user_id = #{userId}</if>
            <if test="operationType != null and operationType != ''">and operation_type = #{operationType}</if>
            <if test="targetType != null and targetType != ''">and target_type = #{targetType}</if>
        </where>
        order by operation_time desc
    </select>

    <insert id="insertSysPermissionAuditLog" parameterType="com.ruoyi.system.domain.SysPermissionAuditLog" useGeneratedKeys="true" keyProperty="logId">
        insert into sys_permission_audit_log (
            <if test="userId != null">user_id,</if>
            <if test="userName != null and userName != ''">user_name,</if>
            <if test="operationType != null and operationType != ''">operation_type,</if>
            <if test="targetType != null and targetType != ''">target_type,</if>
            <if test="targetId != null">target_id,</if>
            <if test="operationDetail != null and operationDetail != ''">operation_detail,</if>
            <if test="ipAddress != null and ipAddress != ''">ip_address,</if>
            operation_time,
            create_time
        )values(
            <if test="userId != null">#{userId},</if>
            <if test="userName != null and userName != ''">#{userName},</if>
            <if test="operationType != null and operationType != ''">#{operationType},</if>
            <if test="targetType != null and targetType != ''">#{targetType},</if>
            <if test="targetId != null">#{targetId},</if>
            <if test="operationDetail != null and operationDetail != ''">#{operationDetail},</if>
            <if test="ipAddress != null and ipAddress != ''">#{ipAddress},</if>
            sysdate(),
            sysdate()
        )
    </insert>

</mapper>
